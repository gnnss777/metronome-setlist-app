# Metronomo Setlist App
# Variáveis de Ambiente Opcionais

# Desenvolvimento
NEXT_PUBLIC_ENV=development

# PWA Configurações
NEXT_PUBLIC_APP_NAME=Metronomo
NEXT_PUBLIC_APP_DESCRIPTION=App de metrônomo profissional com gestão de setlists

# API Keys (se necessário)
# GOOGLE_ANALYTICS_ID=
# AMPLITUDE_KEY=
# SENTRY_DSN=

# Backend API (se necessário)
# API_URL=http://localhost:3001/api

# Performance Configurações
# CHUNK_SIZE=1000
# MAX_WORKERS=4
